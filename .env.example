# Required
SECRET_KEY=change-me-to-a-random-string
DATABASE_URL=postgresql+asyncpg://aso_user:aso_pass@postgres:5432/aso_db
DATABASE_URL_SYNC=postgresql://aso_user:aso_pass@postgres:5432/aso_db
REDIS_URL=redis://redis:6379/0

# Optional (also manageable via UI Settings)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_PACKAGE_NAME=com.NetSafe.VPN
GOOGLE_API_DISCOVERY_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SERPAPI_KEY=

# Defaults (overridable via UI)
DRY_RUN=true
MAX_PUBLISH_PER_DAY=1
MAX_PUBLISH_PER_WEEK=5
AUTO_APPROVE_THRESHOLD=1
